# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false

# ── Redis ─────────────────────────────────────────────────────────────────────
# Docker: redis://:PASSWORD@redis:6379   |   Local: redis://localhost:6379
REDIS_URL=redis://:changeme@redis:6379
# Must match the password in docker-compose.yml
REDIS_PASSWORD=changeme

# ── Cache TTL (seconds) ───────────────────────────────────────────────────────
CACHE_TTL_SEARCH=600
CACHE_TTL_ARTICLE=1800

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_SEARCH=30/minute
RATE_LIMIT_READ=60/minute
RATE_LIMIT_IMAGE=120/minute

# ── Admin Panel ───────────────────────────────────────────────────────────────
# Run: python scripts/generate_admin.py  to generate all three values below.
ADMIN_PATH=
ADMIN_PASSWORD_HASH=
ADMIN_SECRET_KEY=

# ── Proxy Settings ────────────────────────────────────────────────────────────
MAX_DOWNLOAD_SIZE=8388608
REQUEST_TIMEOUT=15.0

# ── DuckDuckGo ────────────────────────────────────────────────────────────────
DDG_URL=https://html.duckduckgo.com/html/

# ── Reddit API (optional — enables post details + comments) ───────────────────
# Register a FREE "script" app (no approval needed) at:
# https://www.reddit.com/prefs/apps
#   1. Click "create another app"
#   2. Choose type: script
#   3. Name: FrogFindNG  /  Redirect URI: http://localhost
#   4. Copy the client_id (under app name) and client_secret
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
